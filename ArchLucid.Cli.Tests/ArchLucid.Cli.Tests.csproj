  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ArchLucid.Cli\ArchLucid.Cli.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>
</Project>
