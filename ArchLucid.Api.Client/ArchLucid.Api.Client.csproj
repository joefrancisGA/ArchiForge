<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ArchLucid.Api.Client</RootNamespace>
    <IsPackable>true</IsPackable>
    <PackageId>ArchLucid.Api.Client</PackageId>
    <Version>$(ArchLucidApiClientPackageVersion)</Version>
    <AssemblyVersion>$(ArchLucidApiClientPackageVersion)</AssemblyVersion>
    <FileVersion>$(ArchLucidApiClientPackageVersion)</FileVersion>
    <Title>ArchLucid API HTTP client (OpenAPI v1)</Title>
    <Description>NSwag-generated HTTP client for ArchLucid API v1. Built from the same OpenAPI document as contract tests (ArchLucid.Api.Tests Contracts/openapi-v1.contract.snapshot.json). Set BaseUrl on the client to your API host.</Description>
    <PackageTags>ArchLucid;OpenAPI;NSwag;HttpClient</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- 1591: missing XML on NSwag-generated members. TreatWarningsAsErrors is set repo-wide; add analyzer/compiler codes here only for Generated/*.g.cs output—never broaden NoWarn to hide issues in hand-written code. -->
    <NoWarn>$(NoWarn);1591</NoWarn>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NSwag.MSBuild">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="nswag.json" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ArchLucidApiClientPackage.cs" />
    <Compile Include="ArchLucidApiClientSerializerSettings.cs" />
  </ItemGroup>

  <Target Name="GenerateArchLucidOpenApiClient" BeforeTargets="BeforeCompile" DependsOnTargets="PrepareForBuild">
    <MakeDir Directories="$(MSBuildProjectDirectory)/Generated" />
    <Exec Command="$(NSwagExe_Net90) run &quot;$(MSBuildProjectDirectory)/nswag.json&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)" />
    <ItemGroup>
      <Compile Include="$(MSBuildProjectDirectory)/Generated/ArchLucidApiClient.g.cs" />
    </ItemGroup>
  </Target>

</Project>
