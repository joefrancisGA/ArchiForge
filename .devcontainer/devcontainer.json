{
  "name": "ArchLucid (.NET + Node)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "dotnet restore ArchLucid.sln",
  "customizations": {
    "vscode": {
      "extensions": ["ms-dotnettools.csdevkit", "dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  },
  "forwardPorts": [5128, 3000],
  "portsAttributes": {
    "5128": { "label": "ArchLucid API (host-run)" },
    "3000": { "label": "Operator UI (host-run)" }
  }
}
