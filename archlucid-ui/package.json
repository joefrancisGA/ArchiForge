{
  "name": "archlucid-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "generate:pricing": "node ./scripts/invoke-generate-pricing.mjs",
    "clean:next-export": "node ./scripts/clean-next-export.mjs",
    "build": "npm run generate:pricing && npm run clean:next-export && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:vitest-single-worker": "vitest run --pool=forks --maxWorkers=1",
    "test:axe-components": "vitest run src/accessibility",
    "test:e2e": "playwright test -c playwright.mock.config.ts",
    "test:a11y": "playwright test -c playwright.mock.config.ts e2e/a11y.spec.ts",
    "e2e:mock": "playwright test -c playwright.mock.config.ts",
    "screenshots": "playwright test -c playwright.mock.config.ts capture-marketing-screenshots.spec.ts",
    "screenshots:all": "playwright test -c playwright.mock.config.ts capture-all-screenshots.spec.ts",
    "screenshots:demo": "playwright test --project=chromium e2e/live-api-demo-screenshots.spec.ts",
    "screenshots:all:prebuilt": "node ./scripts/run-screenshots-all-prebuilt.mjs",
    "test:e2e:live": "playwright test",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "generate:api-types": "openapi-typescript ../ArchLucid.Api.Tests/Contracts/openapi-v1.contract.snapshot.json -o src/lib/api-types.generated.ts",
    "rebrand-check": "python3 ../scripts/ci/assert_brand_category_seam.py"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "reactflow": "^11.11.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "toml": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "9.39.4",
    "eslint-config-next": "^15.5.15",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "eslint": "9.39.4"
  }
}
