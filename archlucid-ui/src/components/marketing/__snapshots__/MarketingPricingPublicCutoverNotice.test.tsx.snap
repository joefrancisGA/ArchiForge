// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`MarketingPricingPublicCutoverNotice > matches snapshot (Marketplace go-live / public price list notice) 1`] = `
<aside
  aria-label="Public price list and Marketplace go-live timing"
  class="mb-6 rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 dark:border-neutral-800 dark:bg-neutral-900/40 dark:text-neutral-300"
>
  When ArchLucid lists on Azure Marketplace (targeting Q2 2026), published list prices become our canonical public packaging. Until then, figures may change — confirm a quote with your account team before budgeting.
</aside>
`;
