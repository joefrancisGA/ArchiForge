# Backend API (used by Next.js server: RSC + /api/proxy)
ARCHLUCID_API_BASE_URL=http://localhost:5128

# Optional: explicit API origin for the public marketing `/demo/preview` page (server-side fetch, no `/api/proxy`).
# When unset, the page falls back to ARCHLUCID_API_BASE_URL then NEXT_PUBLIC_ARCHLUCID_API_BASE_URL.
# NEXT_PUBLIC_DEMO_PREVIEW_API_BASE=http://localhost:5128

# Optional: when API has ApiKey auth
ARCHLUCID_API_KEY=

# Public base URL (optional; defaults below). Browser calls go through /api/proxy instead.
NEXT_PUBLIC_ARCHLUCID_API_BASE_URL=http://localhost:5128

# Canonical public site URL for Open Graph / metadata (no trailing slash). Production: https://app.yourdomain.com
# NEXT_PUBLIC_ARCHLUCID_SITE_URL=http://localhost:3000

# Prefix for in-app Help panel and glossary "Learn more" doc links (see src/lib/help-topics.ts getDocHref).
# Default matches the public ArchLucid repo on GitHub `main` (same as src/lib/docs-public-base.ts when unset).
# Override for a private docs site or a fork, e.g. https://github.com/your-org/your-fork/blob/main
NEXT_PUBLIC_DOCS_BASE_URL=https://github.com/joefrancisGA/ArchLucid/blob/main

# Optional: override "Learn more" blob base in ContextualHelp only (see contextual-help-content.ts toDocsBlobUrl).
# When unset, same base as NEXT_PUBLIC_DOCS_BASE_URL / HelpPanel default.
# NEXT_PUBLIC_ARCHLUCID_DOCS_BLOB_BASE=https://github.com/your-org/your-fork/blob/main

# Optional: trace viewer deep link on run detail / provenance (placeholder {traceId} — from API X-Trace-Id header)
# NEXT_PUBLIC_TRACE_VIEWER_URL_TEMPLATE=https://jaeger.example.com/trace/{traceId}

# UI auth seam: development-bypass | jwt | jwt-bearer (must align with API auth mode in appsettings)
NEXT_PUBLIC_ARCHLUCID_AUTH_MODE=development-bypass

# OIDC (authorization code + PKCE) when NEXT_PUBLIC_ARCHLUCID_AUTH_MODE=jwt — register SPA redirect URI in Entra / IdP
# NEXT_PUBLIC_OIDC_AUTHORITY=https://login.microsoftonline.com/<tenant-id>/v2.0
# NEXT_PUBLIC_OIDC_CLIENT_ID=<spa-app-client-id>
# Include API scope so access token audience matches the API registration audience, e.g. api://<api-app-id>/access_as_user
# NEXT_PUBLIC_OIDC_SCOPES=openid profile offline_access api://<api-app-id>/access_as_user
# Optional fixed redirect (default: {origin}/auth/callback)
# NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Optional after logout (default: {origin}/)
# NEXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# Optional: /api/proxy rate limit (in-process, per server instance). First X-Forwarded-For hop or X-Real-Ip.
# ARCHLUCID_PROXY_RATE_LIMIT_PER_MINUTE=120
# ARCHLUCID_PROXY_RATE_LIMIT_WINDOW_MS=60000
# ARCHLUCID_PROXY_RATE_LIMIT_DISABLED=true

# Operator shell: hidden by default (`/settings/tenant-cost`, `/recommendation-learning`, `/product-learning`) until demos are wired.
# `next dev` sets this automatically via `.env.development`; set explicitly for screenshot builds or CI that need full nav.
# NEXT_PUBLIC_OPERATOR_NAV_SHOW_PRE_RELEASE_ROUTES=1
