# Loaded automatically in `next dev` (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables).
# Ensures Help panel and contextual "Open documentation" links resolve without copying `.env.local`.
NEXT_PUBLIC_DOCS_BASE_URL=https://github.com/joefrancisGA/ArchLucid/blob/main
# Full sidebar links including tenant cost and learning routes (omit in screenshot-only/demo prod if those pages are not ready).
NEXT_PUBLIC_OPERATOR_NAV_SHOW_PRE_RELEASE_ROUTES=1
