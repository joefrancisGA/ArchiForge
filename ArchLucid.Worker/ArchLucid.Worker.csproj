<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ArchiForge.Worker</RootNamespace>
    <AssemblyName>ArchiForge.Worker</AssemblyName>
    <UserSecretsId>archiforge-worker-host</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ArchiForge.Host.Core\ArchiForge.Host.Core.csproj" />
    <ProjectReference Include="..\ArchiForge.Host.Composition\ArchiForge.Host.Composition.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\schemas\*.schema.json" Link="schemas\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
