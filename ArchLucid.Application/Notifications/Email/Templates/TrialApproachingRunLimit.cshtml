@model ArchLucid.Application.Notifications.Email.Models.TrialApproachingRunLimitEmailModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
</head>
<body>
@if (!string.IsNullOrWhiteSpace(Model.LogoImageUrl))
{
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
        <tr>
            <td>
                <img src="@Model.LogoImageUrl" alt="@Model.ProductName" width="96" height="96" style="display:block;width:96px;height:96px;border:0;"/>
            </td>
        </tr>
    </table>
}
<p>@Model.ProductName trial: you have used @Model.RunsUsed of @Model.RunsLimit trial runs.</p>
<p>Consider converting before new architecture requests are blocked.</p>
</body>
</html>
