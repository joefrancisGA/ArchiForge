@model ArchLucid.Application.Notifications.Email.Models.TrialFirstRunEmailModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
</head>
<body>
@if (!string.IsNullOrWhiteSpace(Model.LogoImageUrl))
{
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
        <tr>
            <td>
                <img src="@Model.LogoImageUrl" alt="@Model.ProductName" width="96" height="96" style="display:block;width:96px;height:96px;border:0;"/>
            </td>
        </tr>
    </table>
}
<p>Your first architecture run completed in @Model.ProductName.</p>
<p>Next: <a href="@Model.GettingStartedUrl">open getting started</a> to review manifests, exports, and governance.</p>
</body>
</html>
