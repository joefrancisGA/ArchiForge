@model ArchLucid.Application.Notifications.Email.Models.TrialWelcomeEmailModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/><title>Welcome</title>
</head>
<body>
@if (!string.IsNullOrWhiteSpace(Model.LogoImageUrl))
{
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
        <tr>
            <td>
                <img src="@Model.LogoImageUrl" alt="@Model.ProductName" width="96" height="96" style="display:block;width:96px;height:96px;border:0;"/>
            </td>
        </tr>
    </table>
}
<p>Welcome to @Model.ProductName.</p>
<p>Your trial workspace is ready. Organization: @Model.OrganizationHint</p>
<p><strong>Getting started:</strong> create a run, review the seeded sample pipeline, then explore governance.</p>
</body>
</html>
