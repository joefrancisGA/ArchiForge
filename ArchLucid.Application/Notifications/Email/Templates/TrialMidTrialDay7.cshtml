@model ArchLucid.Application.Notifications.Email.Models.TrialMidTrialEmailModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
</head>
<body>
@if (!string.IsNullOrWhiteSpace(Model.LogoImageUrl))
{
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
        <tr>
            <td>
                <img src="@Model.LogoImageUrl" alt="@Model.ProductName" width="96" height="96" style="display:block;width:96px;height:96px;border:0;"/>
            </td>
        </tr>
    </table>
}
<p>Mid-trial check-in from @Model.ProductName.</p>
<p>How is the guided workflow going? Open your <a href="@Model.DashboardUrl">operator dashboard</a> for runs, manifests, and compare/replay.</p>
</body>
</html>
