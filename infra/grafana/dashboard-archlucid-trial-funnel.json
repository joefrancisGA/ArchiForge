      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(archlucid_trial_runs_used_ratio_bucket[15m])) by (le))",
