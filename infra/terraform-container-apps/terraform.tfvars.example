# Copy to terraform.tfvars (gitignored). Leave enable_container_apps = false until you target Azure.

enable_container_apps = true
create_resource_group   = true
resource_group_name     = "rg-archiforge-ca-dev"
location                = "eastus2"

# Build and push images (repo root). Dockerfile publishes ArchiForge.Worker + ArchiForge.Api into one image; default entrypoint is the API.
#   docker build -f ArchiForge.Api/Dockerfile -t <acr>.azurecr.io/archiforge:2026.04.1 .
# Worker container app runs: dotnet ArchiForge.Worker.dll (same image as API unless you set worker_container_image).
#   docker build -t <acr>.azurecr.io/archiforge-ui:2026.04.1 archiforge-ui/
api_container_image = "<your-acr>.azurecr.io/archiforge:2026.04.1"
ui_container_image  = "<your-acr>.azurecr.io/archiforge-ui:2026.04.1"

# Optional: use a different image for the worker (default: same as api_container_image).
# worker_container_image = "<your-acr>.azurecr.io/archiforge-worker:2026.04.1"

# Optional: cap Log Analytics ingestion (GB/day) for FinOps (0 = omit / no Terraform cap).
# log_analytics_daily_quota_gb = 5

# Replica bounds (HTTP concurrent-request scale rules apply between min and max).
# Default module value is 2 (staging/production). Use 1 only for pilots where duplicate background jobs are OK to avoid.
api_min_replicas = 2
api_max_replicas = 5
ui_min_replicas  = 1
ui_max_replicas  = 3

# Background worker (advisory scan, archival, retrieval outbox, durable export jobs). Scale-out is safe for durable jobs (SQL row lock + batch dequeue); advisory/archival still run per replica.
worker_min_replicas = 1
worker_max_replicas = 20

# Optional: KEDA-style queue depth scaling for the worker (requires background_jobs_mode = "Durable" and a storage connection string for the scaler secret only).
# worker_enable_queue_depth_scaling              = true
# worker_queue_scale_connection_string           = "DefaultEndpointsProtocol=..." # sensitive; prefer TF_VAR_ or Key Vault–backed pipeline secret
# worker_queue_depth_target_messages_per_revision = 10

api_scale_concurrent_requests = 10
ui_scale_concurrent_requests  = 20

# Large artifact offload (golden manifests, bundles, artifact content) — required when enable_container_apps = true.
# Apply infra/terraform-storage first; use its outputs (primary_blob_endpoint, storage_account_id).
artifact_blob_service_uri     = "https://<storage-account>.blob.core.windows.net/"
artifact_storage_account_id   = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<name>"

# Optional: durable async export jobs (SQL + Storage Queue + worker). Requires Sql + AzureBlob + ConnectionStrings:ArchiForge in app config.
# background_jobs_mode             = "Durable"
# background_jobs_queue_name       = "archiforge-export-jobs"
# background_jobs_results_container = "background-job-results"

# Optional: VNet-integrated environment (subnet must be delegated to Microsoft.App/environments).
# container_apps_subnet_id                 = "/subscriptions/.../subnets/snet-container-apps"
# container_apps_internal_load_balancer    = true

tags = {
  workload = "archiforge"
  tier     = "dev"
}

# Optional FinOps keys (merged with tags and Application = ArchiForge on resources).
# finops_environment  = "dev"
# finops_cost_center  = "engineering"

# Optional: resource-group consumption budget for Container Apps + managed environments (requires enable_container_apps = true).
# enable_container_apps_consumption_budget     = true
# container_apps_consumption_budget_amount     = 500
# container_apps_consumption_budget_contact_emails = ["finops@example.com"]
