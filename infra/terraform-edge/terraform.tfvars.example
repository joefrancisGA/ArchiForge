# Copy to terraform.tfvars (gitignored). Keep enable_front_door_waf = false until origins exist.
# Production WAF + DRS version example: production.tfvars.example.

enable_front_door_waf = true
create_resource_group = true
resource_group_name   = "rg-archlucid-edge"
location              = "eastus2"

# Globally unique name (alphanumeric + hyphen).
front_door_profile_name = "archlucid-dev-fd"

# Origin: APIM gateway hostname (no scheme), e.g. archlucid-dev-apim.azure-api.net
backend_hostname = "archlucid-dev-apim.azure-api.net"

# ArchLucid API readiness (default). UI-only origin: use "/".
# front_door_health_probe_path = "/health/ready"

# Optional passive standby (paired region APIM or API hostname). Empty = single origin.
# secondary_backend_hostname = "archlucid-dev-apim-westus2.azure-api.net"

tags = {
  workload = "archlucid"
  layer    = "edge-waf"
}
