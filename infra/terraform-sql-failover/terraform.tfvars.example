# Copy to terraform.tfvars (untracked) and adjust. Default: no resources.
# Production-oriented budgets and failover settings: see production.tfvars.example.

enable_sql_failover_group = false

# failover_group_name     = "archlucid-prod-sqlfg"
# primary_sql_server_resource_id   = "/subscriptions/.../resourceGroups/rg-primary/providers/Microsoft.Sql/servers/sql-primary"
# partner_sql_server_resource_id   = "/subscriptions/.../resourceGroups/rg-secondary/providers/Microsoft.Sql/servers/sql-secondary"
# database_resource_ids = [
#   "/subscriptions/.../resourceGroups/rg-primary/providers/Microsoft.Sql/servers/sql-primary/databases/ArchLucid",
# ]

# read_write_failover_mode         = "Automatic"
# read_write_grace_minutes         = 60
# readonly_endpoint_failover_enabled = true

# tags = {
#   Environment = "production"
#   Workload    = "archi-forge"
# }

# Optional: resource-group consumption budget filtered to Microsoft.Sql/servers + databases (Cost Management).
# enable_sql_consumption_budget = true
# sql_consumption_budget_resource_group_id = "/subscriptions/.../resourceGroups/rg-sql" # or omit to derive from primary_sql_server_resource_id
# sql_consumption_budget_amount            = 500
# sql_consumption_budget_contact_emails    = ["finops@example.com"]
