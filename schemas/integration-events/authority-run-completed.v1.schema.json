{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archlucid.dev/schemas/integration-events/authority-run-completed.v1.schema.json",
  "title": "com.archlucid.authority.run.completed",
  "description": "Service Bus message after an authority run commits successfully (canonical com.archlucid.authority.run.completed; legacy com.archiforge.authority.run.completed).",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "manifestId",
    "tenantId",
    "workspaceId",
    "projectId"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runId": { "type": "string", "format": "uuid" },
    "manifestId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "workspaceId": { "type": "string", "format": "uuid" },
    "projectId": { "type": "string", "format": "uuid" }
  },
  "additionalProperties": true
}
