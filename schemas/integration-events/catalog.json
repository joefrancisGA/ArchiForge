{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchLucid Integration Event Schema Catalog",
  "description": "Machine-readable index of all outbound integration event JSON Schemas.",
  "version": "1.0.0",
  "events": [
    {
      "eventType": "com.archlucid.authority.run.completed",
      "schemaVersion": 1,
      "schemaFile": "authority-run-completed.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/authority-run-completed.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when an authority run completes successfully.",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.manifest.finalized.v1",
      "schemaVersion": 1,
      "schemaFile": "manifest-finalized.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/manifest-finalized.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a golden manifest is finalized (committed) for a run in the same transaction as the run header update.",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.governance.approval.submitted",
      "schemaVersion": 1,
      "schemaFile": "governance-approval-submitted.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/governance-approval-submitted.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a governance approval request is submitted.",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.governance.promotion.activated",
      "schemaVersion": 1,
      "schemaFile": "governance-promotion-activated.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/governance-promotion-activated.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a governance promotion environment activation completes.",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.alert.fired",
      "schemaVersion": 1,
      "schemaFile": "alert-fired.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/alert-fired.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when an alert is raised for a scope (run/comparison context). Service Bus user properties: severity, deduplication_key (see INTEGRATION_EVENTS_AND_WEBHOOKS.md).",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.alert.resolved",
      "schemaVersion": 1,
      "schemaFile": "alert-resolved.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/alert-resolved.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when an alert is resolved. Service Bus user property deduplication_key when payload includes deduplicationKey (ChatOps card correlation).",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.advisory.scan.completed",
      "schemaVersion": 1,
      "schemaFile": "advisory-scan-completed.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/advisory-scan-completed.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a scheduled advisory scan execution completes.",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.system.data-consistency-check.completed.v1",
      "schemaVersion": 1,
      "schemaFile": "data-consistency-check-completed.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/data-consistency-check-completed.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": false,
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.compliance.drift.escalated",
      "schemaVersion": 1,
      "schemaFile": "compliance-drift-escalated.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/compliance-drift-escalated.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a compliance drift signal crosses its escalation threshold (Teams notification trigger).",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.seat.reservation.released",
      "schemaVersion": 1,
      "schemaFile": "seat-reservation-released.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/seat-reservation-released.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted when a trial seat reservation is released or expires, freeing capacity (Teams notification trigger).",
      "audience": "external"
    },
    {
      "eventType": "com.archlucid.notifications.trial-lifecycle-email.v1",
      "schemaVersion": 1,
      "schemaFile": "trial-lifecycle-email.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/trial-lifecycle-email.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Requests dispatch of a trial lifecycle transactional email (worker-side idempotency ledger).",
      "internal": true
    },
    {
      "eventType": "com.archlucid.billing.marketplace.webhook.received.v1",
      "schemaVersion": 1,
      "schemaFile": "billing-marketplace-webhook-received.v1.schema.json",
      "schemaUri": "https://archlucid.dev/schemas/integration-events/billing-marketplace-webhook-received.v1.schema.json",
      "transport": "Azure Service Bus (topic)",
      "outboxSupported": true,
      "description": "Emitted after a Marketplace SaaS webhook is verified, deduped in SQL, and processed (Logic Apps / external fulfillment fan-out).",
      "audience": "external"
    }
  ]
}
