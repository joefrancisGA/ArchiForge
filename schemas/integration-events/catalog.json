{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchLucid Integration Event Schema Catalog",
  "description": "Machine-readable index of all outbound integration event JSON Schemas.",
  "version": "1.0.0",
  "events": [
    {
      "eventType": "com.archlucid.authority.run.completed",
      "schemaVersion": 1,
      "schemaFile": "authority-run-completed.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when an authority run completes successfully."
    },
    {
      "eventType": "com.archlucid.governance.approval.submitted",
      "schemaVersion": 1,
      "schemaFile": "governance-approval-submitted.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when a governance approval request is submitted."
    },
    {
      "eventType": "com.archlucid.governance.promotion.activated",
      "schemaVersion": 1,
      "schemaFile": "governance-promotion-activated.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when a governance promotion environment activation completes."
    },
    {
      "eventType": "com.archlucid.alert.fired",
      "schemaVersion": 1,
      "schemaFile": "alert-fired.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when an alert is raised for a scope (run/comparison context)."
    },
    {
      "eventType": "com.archlucid.alert.resolved",
      "schemaVersion": 1,
      "schemaFile": "alert-resolved.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when an alert is resolved."
    },
    {
      "eventType": "com.archlucid.advisory.scan.completed",
      "schemaVersion": 1,
      "schemaFile": "advisory-scan-completed.v1.schema.json",
      "transport": "azure-service-bus",
      "description": "Emitted when a scheduled advisory scan execution completes."
    }
  ]
}
