# Backend API (used by Next.js server: RSC + /api/proxy)
ARCHIFORGE_API_BASE_URL=http://localhost:5128

# Optional: when ArchiForge API has Authentication:ApiKey:Enabled = true
ARCHIFORGE_API_KEY=

# Public base URL (optional; defaults below). Browser calls go through /api/proxy instead.
NEXT_PUBLIC_ARCHIFORGE_API_BASE_URL=http://localhost:5128

# UI auth seam: development-bypass | jwt | jwt-bearer (must align with API ArchiForgeAuth:Mode)
NEXT_PUBLIC_ARCHIFORGE_AUTH_MODE=development-bypass

# OIDC (authorization code + PKCE) when NEXT_PUBLIC_ARCHIFORGE_AUTH_MODE=jwt — register SPA redirect URI in Entra / IdP
# NEXT_PUBLIC_OIDC_AUTHORITY=https://login.microsoftonline.com/<tenant-id>/v2.0
# NEXT_PUBLIC_OIDC_CLIENT_ID=<spa-app-client-id>
# Include API scope so access token audience matches API ArchiForgeAuth:Audience, e.g. api://<api-app-id>/access_as_user
# NEXT_PUBLIC_OIDC_SCOPES=openid profile offline_access api://<api-app-id>/access_as_user
# Optional fixed redirect (default: {origin}/auth/callback)
# NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Optional after logout (default: {origin}/)
# NEXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# Optional: /api/proxy rate limit (in-process, per server instance). First X-Forwarded-For hop or X-Real-Ip.
# ARCHIFORGE_PROXY_RATE_LIMIT_PER_MINUTE=120
# ARCHIFORGE_PROXY_RATE_LIMIT_WINDOW_MS=60000
# ARCHIFORGE_PROXY_RATE_LIMIT_DISABLED=true
