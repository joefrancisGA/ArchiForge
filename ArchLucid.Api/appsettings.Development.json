{
  "ArchLucidAuth": {
    "Mode": "DevelopmentBypass"
  },
  "Authentication": {
    "ApiKey": {
      "DevelopmentBypassAll": false
    }
  },
  "HotPathCache": {
    "Enabled": false
  },
  "Demo": {
    "Enabled": true,
    "SeedOnStartup": true
  },
  "DeveloperExperience": {
    "EnableApiExplorer": true
  },
  "DataConsistency": {
    "InitialDelaySeconds": 0
  },
  "Billing": {
    "Provider": "Noop"
  },
  "ArchLucid": {
    "StorageProvider": "InMemory",
    "AgentOutput": {
      "QualityGate": {
        "Enabled": true,
        "StructuralWarnBelow": 0.3,
        "SemanticWarnBelow": 0.2,
        "StructuralRejectBelow": 0,
        "SemanticRejectBelow": 0
      }
    }
  },
  "CosmosDb": {
    "ConnectionString": "AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjj5/R+ob0NPNB0y=Yg==",
    "DatabaseName": "ArchLucid",
    "GraphSnapshotsEnabled": false,
    "AgentTracesEnabled": false,
    "AuditEventsEnabled": false
  },
  "AgentExecution": {
    "Mode": "Simulator",
    "LlmCostEstimation": {
      "Enabled": true,
      "InputUsdPerMillionTokens": 0.5,
      "OutputUsdPerMillionTokens": 1.5
    }
  },
  "AgentRuntime": {
    "CompletionCache": {
      "Enabled": true
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "RateLimiting": {
    "FixedWindow": {
      "PermitLimit": 2000,
      "WindowMinutes": 1,
      "QueueLimit": 0
    },
    "Expensive": {
      "PermitLimit": 100000,
      "WindowMinutes": 1,
      "QueueLimit": 0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
